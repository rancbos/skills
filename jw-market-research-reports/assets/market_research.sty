% market_research.sty - 专业市场研究报告样式
% 适用于 XeLaTeX 或 LuaLaTeX
% 样式灵感来自顶级咨询公司（麦肯锡、BCG、Gartner）

\ProvidesPackage{market_research}[2024/01/01 市场研究报告样式]

% ============================================================================
% 必需宏包
% ============================================================================

% 页面布局与几何
\RequirePackage[margin=1in]{geometry}
\RequirePackage{setspace}

% 中文支持（XeLaTeX）
\RequirePackage{xeCJK}
\setCJKmainfont{Noto Sans CJK SC}
\setCJKsansfont{Noto Sans CJK SC}
\setCJKmonofont{Noto Sans Mono CJK SC}

% 排版
\RequirePackage[utf8]{inputenc}
\RequirePackage[T1]{fontenc}
\RequirePackage{helvet}
\renewcommand{\familydefault}{\sfdefault}

% 颜色与图形
\RequirePackage{xcolor}
\RequirePackage{graphicx}
\RequirePackage{tikz}

% 表格
\RequirePackage{longtable}
\RequirePackage{booktabs}
\RequirePackage{multirow}
\RequirePackage{array}
\RequirePackage{colortbl}

% 列表与格式
\RequirePackage{enumitem}
\RequirePackage{parskip}

% 框与提示
\RequirePackage[most]{tcolorbox}

% 页眉页脚
\RequirePackage{fancyhdr}
\RequirePackage{titlesec}

% 超链接与引用
\RequirePackage{hyperref}
\RequirePackage[numbers,sort&compress]{natbib}

% 数学（用于财务预测）
\RequirePackage{amsmath}

% 题注
\RequirePackage{caption}
\RequirePackage{subcaption}

% ============================================================================
% 颜色定义
% ============================================================================

% 主色（专业蓝色调）
\definecolor{primaryblue}{RGB}{0, 51, 102}        % 深海军蓝
\definecolor{secondaryblue}{RGB}{51, 102, 153}    % 中蓝
\definecolor{lightblue}{RGB}{173, 216, 230}       % 浅蓝背景
\definecolor{accentblue}{RGB}{0, 120, 215}        % 亮强调蓝

% 辅助色（互补色）
\definecolor{accentgreen}{RGB}{0, 128, 96}        % 蓝绿色
\definecolor{lightgreen}{RGB}{200, 230, 201}      % 浅绿背景
\definecolor{darkgreen}{RGB}{27, 94, 32}          % 深绿

% 警告与风险色
\definecolor{warningorange}{RGB}{255, 140, 0}     % 橙色警告
\definecolor{lightorange}{RGB}{255, 243, 224}     % 浅橙背景
\definecolor{alertred}{RGB}{198, 40, 40}          % 红色严重
\definecolor{lightred}{RGB}{255, 235, 238}        % 浅红背景

% 建议与行动色
\definecolor{recommendpurple}{RGB}{103, 58, 183}  % 紫色建议
\definecolor{lightpurple}{RGB}{237, 231, 246}     % 浅紫背景

% 中性色
\definecolor{darkgray}{RGB}{66, 66, 66}           % 深灰正文
\definecolor{mediumgray}{RGB}{117, 117, 117}      % 中灰
\definecolor{lightgray}{RGB}{240, 240, 240}       % 浅灰背景
\definecolor{tablegray}{RGB}{250, 250, 250}       % 表格交替行
\definecolor{tablealt}{RGB}{245, 247, 250}        % 交替行色

% 图表色（色盲友好调色板）
\definecolor{chart1}{RGB}{0, 114, 178}            % 蓝
\definecolor{chart2}{RGB}{230, 159, 0}            % 橙
\definecolor{chart3}{RGB}{0, 158, 115}            % 绿
\definecolor{chart4}{RGB}{204, 121, 167}          % 粉
\definecolor{chart5}{RGB}{86, 180, 233}           % 天蓝
\definecolor{chart6}{RGB}{213, 94, 0}             % 朱红
\definecolor{chart7}{RGB}{240, 228, 66}           % 黄

% ============================================================================
% 超链接配置
% ============================================================================

\hypersetup{
    colorlinks=true,
    linkcolor=primaryblue,
    filecolor=primaryblue,
    urlcolor=accentblue,
    citecolor=secondaryblue,
    pdftitle={市场研究报告},
    pdfauthor={市场情报部},
    pdfsubject={市场分析},
}

% ============================================================================
% 章节格式
% ============================================================================

% 章格式 - 大号编号配彩色标题
\titleformat{\chapter}[display]
{\normalfont\huge\bfseries\color{primaryblue}}
{\chaptertitlename\ \thechapter}{20pt}{\Huge}
\titlespacing*{\chapter}{0pt}{-20pt}{40pt}

% 节格式
\titleformat{\section}
{\normalfont\Large\bfseries\color{primaryblue}}
{\thesection}{1em}{}
\titlespacing*{\section}{0pt}{3.5ex plus 1ex minus .2ex}{2.3ex plus .2ex}

% 子节格式
\titleformat{\subsection}
{\normalfont\large\bfseries\color{secondaryblue}}
{\thesubsection}{1em}{}

% 子子节格式
\titleformat{\subsubsection}
{\normalfont\normalsize\bfseries\color{darkgray}}
{\thesubsubsection}{1em}{}

% 段落格式
\titleformat{\paragraph}[runin]
{\normalfont\normalsize\bfseries\color{darkgray}}
{\theparagraph}{1em}{}

% ============================================================================
% 页眉页脚配置
% ============================================================================

\pagestyle{fancy}
\fancyhf{}
\fancyhead[L]{\small\textit{\leftmark}}
\fancyhead[R]{\small\textit{市场研究报告}}
\fancyfoot[C]{\thepage}
\renewcommand{\headrulewidth}{0.4pt}
\renewcommand{\footrulewidth}{0.4pt}
\renewcommand{\headrule}{\hbox to\headwidth{\color{primaryblue}\leaders\hrule height \headrulewidth\hfill}}
\renewcommand{\footrule}{\hbox to\headwidth{\color{lightgray}\leaders\hrule height \footrulewidth\hfill}}

% 章首页使用简洁页面样式
\fancypagestyle{plain}{
    \fancyhf{}
    \fancyfoot[C]{\thepage}
    \renewcommand{\headrulewidth}{0pt}
    \renewcommand{\footrulewidth}{0.4pt}
}

% ============================================================================
% 框环境
% ============================================================================

% 核心洞察框（蓝色）- 用于重大发现和洞察
\newtcolorbox{keyinsightbox}[1][核心洞察]{
    colback=lightblue!30,
    colframe=primaryblue,
    fonttitle=\bfseries\color{white},
    title=#1,
    coltitle=white,
    colbacktitle=primaryblue,
    boxrule=1pt,
    arc=3pt,
    left=10pt,
    right=10pt,
    top=8pt,
    bottom=8pt,
    before skip=12pt,
    after skip=12pt,
}

% 市场数据框（绿色）- 用于市场统计数据和数据亮点
\newtcolorbox{marketdatabox}[1][市场数据]{
    colback=lightgreen!50,
    colframe=accentgreen,
    fonttitle=\bfseries\color{white},
    title=#1,
    coltitle=white,
    colbacktitle=accentgreen,
    boxrule=1pt,
    arc=3pt,
    left=10pt,
    right=10pt,
    top=8pt,
    bottom=8pt,
    before skip=12pt,
    after skip=12pt,
}

% 风险提示框（橙色/警告）- 用于风险因素和警告
\newtcolorbox{riskbox}[1][风险因素]{
    colback=lightorange,
    colframe=warningorange,
    fonttitle=\bfseries\color{white},
    title=#1,
    coltitle=white,
    colbacktitle=warningorange,
    boxrule=1pt,
    arc=3pt,
    left=10pt,
    right=10pt,
    top=8pt,
    bottom=8pt,
    before skip=12pt,
    after skip=12pt,
}

% 严重风险框（红色）- 用于严重/高危风险
\newtcolorbox{criticalriskbox}[1][严重风险]{
    colback=lightred,
    colframe=alertred,
    fonttitle=\bfseries\color{white},
    title=#1,
    coltitle=white,
    colbacktitle=alertred,
    boxrule=1pt,
    arc=3pt,
    left=10pt,
    right=10pt,
    top=8pt,
    bottom=8pt,
    before skip=12pt,
    after skip=12pt,
}

% 建议框（紫色）- 用于战略建议
\newtcolorbox{recommendationbox}[1][战略建议]{
    colback=lightpurple,
    colframe=recommendpurple,
    fonttitle=\bfseries\color{white},
    title=#1,
    coltitle=white,
    colbacktitle=recommendpurple,
    boxrule=1pt,
    arc=3pt,
    left=10pt,
    right=10pt,
    top=8pt,
    bottom=8pt,
    before skip=12pt,
    after skip=12pt,
}

% 提示框（灰色）- 用于定义、注释、补充信息
\newtcolorbox{calloutbox}[1][注释]{
    colback=lightgray,
    colframe=mediumgray,
    fonttitle=\bfseries\color{darkgray},
    title=#1,
    coltitle=darkgray,
    colbacktitle=lightgray,
    boxrule=0.5pt,
    arc=3pt,
    left=10pt,
    right=10pt,
    top=8pt,
    bottom=8pt,
    before skip=12pt,
    after skip=12pt,
}

% 执行摘要框（特殊样式）
\newtcolorbox{executivesummarybox}[1][执行摘要]{
    enhanced,
    colback=white,
    colframe=primaryblue,
    fonttitle=\Large\bfseries\color{white},
    title=#1,
    coltitle=white,
    colbacktitle=primaryblue,
    boxrule=2pt,
    arc=5pt,
    left=15pt,
    right=15pt,
    top=12pt,
    bottom=12pt,
    before skip=15pt,
    after skip=15pt,
    shadow={2mm}{-2mm}{0mm}{black!20},
}

% 机会框（蓝绿色）- 用于机会和正向发现
\newtcolorbox{opportunitybox}[1][机会]{
    colback=lightblue!20,
    colframe=accentblue,
    fonttitle=\bfseries\color{white},
    title=#1,
    coltitle=white,
    colbacktitle=accentblue,
    boxrule=1pt,
    arc=3pt,
    left=10pt,
    right=10pt,
    top=8pt,
    bottom=8pt,
    before skip=12pt,
    after skip=12pt,
}

% ============================================================================
% 引用高亮环境
% ============================================================================

\newtcolorbox{pullquote}{
    enhanced,
    colback=lightgray,
    colframe=lightgray,
    boxrule=0pt,
    borderline west={4pt}{0pt}{primaryblue},
    arc=0pt,
    left=15pt,
    right=15pt,
    top=10pt,
    bottom=10pt,
    before skip=15pt,
    after skip=15pt,
    fontupper=\large\itshape\color{darkgray},
}

% ============================================================================
% 数据指标高亮
% ============================================================================

\newcommand{\statbox}[2]{%
    \begin{tcolorbox}[
        colback=primaryblue,
        colframe=primaryblue,
        coltext=white,
        arc=5pt,
        boxrule=0pt,
        width=0.3\textwidth,
        halign=center,
        valign=center,
        before skip=10pt,
        after skip=10pt,
    ]
    {\Huge\bfseries #1}\\[5pt]
    {\small #2}
    \end{tcolorbox}
}

% ============================================================================
% 表格样式
% ============================================================================

% 交替行色命令
\newcommand{\tablerowcolor}{\rowcolor{tablealt}}

% 表头样式
\newcommand{\tableheader}[1]{\textbf{\color{white}#1}}
\newcommand{\tableheaderrow}{\rowcolor{primaryblue}}

% 专业表格环境
\newenvironment{markettable}[2][htbp]{%
    \begin{table}[#1]
    \centering
    \caption{#2}
    \small
}{%
    \end{table}
}

% ============================================================================
% 图片样式
% ============================================================================

% 题注格式
\captionsetup{
    font=small,
    labelfont={bf,color=primaryblue},
    textfont={color=darkgray},
    justification=centering,
    margin=20pt,
}

% 带来源标注的图片
\newcommand{\figuresource}[1]{%
    \par\vspace{-8pt}
    {\small\textit{来源：#1}}
}

% ============================================================================
% 列表样式
% ============================================================================

% 无序列表样式
\setlist[itemize]{
    leftmargin=*,
    label=\textcolor{primaryblue}{\textbullet},
    topsep=5pt,
    itemsep=3pt,
}

% 有序列表样式
\setlist[enumerate]{
    leftmargin=*,
    label=\textcolor{primaryblue}{\arabic*.},
    topsep=5pt,
    itemsep=3pt,
}

% ============================================================================
% 自定义命令
% ============================================================================

% 高亮重要文本
\newcommand{\highlight}[1]{\textbf{\textcolor{primaryblue}{#1}}}

% 市场规模格式化
\newcommand{\marketsize}[1]{\textbf{\textcolor{accentgreen}{#1}}}

% 增长率格式化
\newcommand{\growthrate}[1]{\textbf{\textcolor{chart3}{#1\%}}}

% 风险指示器
\newcommand{\riskhigh}{\textbf{\textcolor{alertred}{高}}}
\newcommand{\riskmedium}{\textbf{\textcolor{warningorange}{中}}}
\newcommand{\risklow}{\textbf{\textcolor{accentgreen}{低}}}

% 评级星级（1-5）
\newcommand{\rating}[1]{%
    \foreach \i in {1,...,5}{%
        \ifnum\i>#1
            \textcolor{lightgray}{$\star$}%
        \else
            \textcolor{warningorange}{$\star$}%
        \fi
    }%
}

% 趋势指示器
\newcommand{\trendup}{\textcolor{accentgreen}{$\blacktriangle$}}
\newcommand{\trenddown}{\textcolor{alertred}{$\blacktriangledown$}}
\newcommand{\trendflat}{\textcolor{mediumgray}{$\rightarrow$}}

% ============================================================================
% 封面页命令
% ============================================================================

\newcommand{\makemarketreporttitle}[5]{%
    % #1 = 报告标题
    % #2 = 副标题
    % #3 = 封面图片路径
    % #4 = 日期
    % #5 = 编制方
    \begin{titlepage}
    \centering
    \vspace*{1cm}

    {\Huge\bfseries\color{primaryblue} #1\\[0.5cm]}
    {\LARGE\bfseries #2\\[2cm]}

    \ifx&#3&
        % 未提供图片
        \vspace{4cm}
    \else
        \includegraphics[width=\textwidth]{#3}\\[2cm]
    \fi

    {\Large\bfseries 市场研究报告\\[3cm]}

    {\large
    \textbf{日期：} #4\\[0.3cm]
    \textbf{编制：} #5\\[0.3cm]
    \textbf{密级：} 机密
    }

    \vfill

    {\footnotesize
    \textit{本报告包含市场情报和战略分析。所有数据来源均已引用并可独立核实。}
    }

    \end{titlepage}
}

% ============================================================================
% 附录章节命令
% ============================================================================

\newcommand{\appendixsection}[1]{%
    \section*{#1}
    \addcontentsline{toc}{section}{#1}
}

